# ============================================================
# Finance Credit Follow-Up Email Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.3

# ── LangSmith (optional) ──────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=finance-credit-agent

# ── Email SMTP ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Finance Collections Team
EMAIL_FROM_ADDRESS=collections@yourcompany.com
EMAIL_DRY_RUN=true

# ── Company / Agent Config ────────────────────────────────
COMPANY_NAME=Acme Finance Ltd
COMPANY_PAYMENT_URL=https://pay.acmefinance.com/invoice
COMPANY_CONTACT_EMAIL=accounts@acmefinance.com
COMPANY_CONTACT_PHONE=+1-800-555-0100
COMPANY_LEGAL_DEPARTMENT=legal@acmefinance.com

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./finance_agent.db

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24
SCHEDULER_START_HOUR=9
SCHEDULER_TIMEZONE=UTC

# ── Security ──────────────────────────────────────────────
MAX_RETRIES=3
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
MASK_PII_IN_LOGS=true

# ── FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
